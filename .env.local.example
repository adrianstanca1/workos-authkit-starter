# Copy to .env.local and fill from https://dashboard.workos.com
WORKOS_CLIENT_ID="client_..."
WORKOS_API_KEY="sk_test_..."
# openssl rand -base64 24   → at least 32 characters
WORKOS_COOKIE_PASSWORD="replace-with-32-plus-char-secret"
# App runs on 3050 by default (see package.json) so this matches npm run dev.
NEXT_PUBLIC_WORKOS_REDIRECT_URI="http://localhost:3050/auth/callback"

# Optional: public site URL for OAuth redirects behind proxies / Vercel (see auth/callback/route.ts)
# NEXT_PUBLIC_APP_URL="http://localhost:3050"
